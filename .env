POSTGRES_USER=stock_user
POSTGRES_PASSWORD=stock_password
POSTGRES_DB=stock_market

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=stock_prices

# Producer
PRODUCER_INTERVAL_SECONDS=1

# --------------------------------------------------
# Data Quality Thresholds
# --------------------------------------------------

DQ_WARNING_REJECTION_RATE_PCT=5
DQ_CRITICAL_REJECTION_RATE_PCT=20

DQ_WARNING_AVG_LATENCY_MS=3000
DQ_CRITICAL_AVG_LATENCY_MS=8000

DQ_CRITICAL_MAX_LATENCY_MS=10000

# --------------------------------------------------
# Alert Configuration
# --------------------------------------------------

DQ_ALERTS_ENABLED=true
DQ_ALERT_PIPELINE_NAME=stock-market-streaming-pipeline