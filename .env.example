# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=stock_market
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=replace-with-local-password


# ============================================================
# External alert notifications
# ============================================================

CRITICAL_EMAIL_NOTIFICATIONS_ENABLED=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-app-password

ALERT_EMAIL_FROM=pipeline-alerts@example.com
ALERT_EMAIL_TO=operations@example.com

EMAIL_NOTIFICATION_MAXIMUM_ATTEMPTS=3
EMAIL_NOTIFICATION_RETRY_DELAY_SECONDS=60
SMTP_CONNECTION_TIMEOUT_SECONDS=30

# ============================================================
# Grafana
# ============================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-local-password